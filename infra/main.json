{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "13240582136095741578"
    }
  },
  "parameters": {
    "projectName": {
      "type": "string",
      "defaultValue": "voycelink",
      "metadata": {
        "description": "Logical application name used to derive resource names."
      }
    },
    "environmentName": {
      "type": "string",
      "defaultValue": "dev",
      "metadata": {
        "description": "Deployment environment name."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "cosmosAccountName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional explicit Cosmos DB account name. Leave empty to generate one."
      }
    },
    "cosmosDatabaseName": {
      "type": "string",
      "defaultValue": "voycelink",
      "metadata": {
        "description": "Cosmos DB SQL database name."
      }
    },
    "cosmosContainers": {
      "type": "array",
      "defaultValue": [
        {
          "name": "rooms",
          "partitionKeyPath": "/roomId"
        },
        {
          "name": "participant-custom-permissions",
          "partitionKeyPath": "/roomId"
        }
      ],
      "metadata": {
        "description": "Cosmos DB SQL containers to provision."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags applied to all supported resources."
      }
    }
  },
  "variables": {
    "normalizedProjectName": "[toLower(replace(parameters('projectName'), '-', ''))]",
    "normalizedEnvironmentName": "[toLower(replace(parameters('environmentName'), '-', ''))]",
    "generatedCosmosAccountName": "[take(format('cdb{0}{1}{2}', variables('normalizedProjectName'), variables('normalizedEnvironmentName'), uniqueString(resourceGroup().id)), 44)]",
    "resolvedCosmosAccountName": "[if(empty(parameters('cosmosAccountName')), variables('generatedCosmosAccountName'), toLower(parameters('cosmosAccountName')))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "cosmosdb-serverless",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "accountName": {
            "value": "[variables('resolvedCosmosAccountName')]"
          },
          "databaseName": {
            "value": "[parameters('cosmosDatabaseName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "containers": {
            "value": "[parameters('cosmosContainers')]"
          },
          "tags": {
            "value": "[union(parameters('tags'), createObject('environment', parameters('environmentName'), 'workload', parameters('projectName'), 'managedBy', 'bicep'))]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "9520553299389710184"
            }
          },
          "parameters": {
            "accountName": {
              "type": "string",
              "metadata": {
                "description": "Cosmos DB account name."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for the account."
              }
            },
            "databaseName": {
              "type": "string",
              "metadata": {
                "description": "Cosmos DB SQL database name."
              }
            },
            "containers": {
              "type": "array",
              "metadata": {
                "description": "SQL containers to create in the database."
              }
            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Tags applied to the Cosmos DB account."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.DocumentDB/databaseAccounts",
              "apiVersion": "2024-05-15",
              "name": "[parameters('accountName')]",
              "location": "[parameters('location')]",
              "kind": "GlobalDocumentDB",
              "tags": "[parameters('tags')]",
              "properties": {
                "databaseAccountOfferType": "Standard",
                "publicNetworkAccess": "Enabled",
                "minimalTlsVersion": "Tls12",
                "locations": [
                  {
                    "locationName": "[parameters('location')]",
                    "failoverPriority": 0,
                    "isZoneRedundant": false
                  }
                ],
                "capabilities": [
                  {
                    "name": "EnableServerless"
                  }
                ],
                "consistencyPolicy": {
                  "defaultConsistencyLevel": "Session"
                }
              }
            },
            {
              "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
              "apiVersion": "2024-05-15",
              "name": "[format('{0}/{1}', parameters('accountName'), parameters('databaseName'))]",
              "properties": {
                "resource": {
                  "id": "[parameters('databaseName')]"
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName'))]"
              ]
            },
            {
              "copy": {
                "name": "sqlContainers",
                "count": "[length(parameters('containers'))]"
              },
              "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
              "apiVersion": "2024-05-15",
              "name": "[format('{0}/{1}/{2}', parameters('accountName'), parameters('databaseName'), parameters('containers')[copyIndex()].name)]",
              "properties": {
                "resource": {
                  "id": "[parameters('containers')[copyIndex()].name]",
                  "partitionKey": {
                    "paths": [
                      "[parameters('containers')[copyIndex()].partitionKeyPath]"
                    ],
                    "kind": "Hash"
                  },
                  "indexingPolicy": {
                    "indexingMode": "consistent",
                    "automatic": true,
                    "includedPaths": [
                      {
                        "path": "/*"
                      }
                    ],
                    "excludedPaths": [
                      {
                        "path": "/\"_etag\"/?"
                      }
                    ]
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', parameters('accountName'), parameters('databaseName'))]"
              ]
            }
          ],
          "outputs": {
            "accountName": {
              "type": "string",
              "value": "[parameters('accountName')]"
            },
            "endpoint": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('accountName')), '2024-05-15').documentEndpoint]"
            },
            "databaseName": {
              "type": "string",
              "value": "[parameters('databaseName')]"
            },
            "containerNames": {
              "type": "array",
              "copy": {
                "count": "[length(parameters('containers'))]",
                "input": "[parameters('containers')[copyIndex()].name]"
              }
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "cosmosAccountName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'cosmosdb-serverless'), '2025-04-01').outputs.accountName.value]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'cosmosdb-serverless'), '2025-04-01').outputs.endpoint.value]"
    },
    "cosmosDatabaseName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'cosmosdb-serverless'), '2025-04-01').outputs.databaseName.value]"
