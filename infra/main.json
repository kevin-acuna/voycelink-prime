    "cosmosConnectionStringSettingName": {
      "type": "string",
      "value": "COSMOS_DB_CONNECTION_STRING"
    },
    "cosmosContainers": {
      "type": "array",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'cosmosdb-serverless'), '2025-04-01').outputs.containerNames.value]"
    }
  }
}