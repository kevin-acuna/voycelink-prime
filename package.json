{
  "name": "ai-dubbing-backend",
  "version": "1.0.0",
  "description": "Backend BFF for AI Live Dubbing Platform - OpenVidu Session/Token management",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && mkdir -p dist/public && cp public/index.html public/styles.css dist/public/",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openvidu-node-client": "^2.29.0",
    "pino": "^10.3.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.8.1",
    "@types/ws": "^8.18.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "nodemon": "^3.0.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "keywords": [
    "openvidu",
    "video-conferencing",
    "ai-dubbing",
    "webrtc"
  ],
  "license": "MIT"
}
